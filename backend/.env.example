# ── Server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Pooled URL  — runtime queries (from Neon dashboard → Connection string → Pooled)
DATABASE_URL=postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1
# Direct URL  — prisma migrate / db push (same but without -pooler and without pgbouncer params)
DIRECT_URL=postgresql://USER:PASS@HOST.REGION.aws.neon.tech/DB?sslmode=require

# ── Auth / JWT ────────────────────────────────────────────────────────────
JWT_SECRET=your_long_random_secret_here
JWT_EXPIRES_IN=7d
# Dev-only: set a UUID to bypass JWT verification in development
DEV_USER_ID=

# ── Frontend origin (CORS) ────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── API Ninjas ────────────────────────────────────────────────────────────
NUTRITION_API_URL=https://api.api-ninjas.com/v1/nutrition
NUTRITION_API_KEY=your_api_ninjas_key
